generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auth
  privyDid      String?  @unique
  twitterId     String?  @unique
  twitterHandle String?  @unique
  twitterName   String?
  twitterAvatar String?
  email         String?  @unique

  // Profile
  username      String?  @unique

  // Circle wallet
  walletId      String?  @unique
  walletAddress String?  @unique

  // Relations
  sentTransfers     Transfer[]       @relation("SentTransfers")
  receivedTransfers Transfer[]       @relation("ReceivedTransfers")
  paymentRequests   PaymentRequest[]
  claimableLinks    ClaimableLink[]
  invoices          Invoice[]

  @@map("users")
}

model Transfer {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())

  senderId    String
  receiverId  String?
  sender      User           @relation("SentTransfers", fields: [senderId], references: [id])
  receiver    User?          @relation("ReceivedTransfers", fields: [receiverId], references: [id])

  // Can send to external wallet too
  toAddress   String?

  amountUsdc  String         // stored as string to avoid float issues
  note        String?
  status      TransferStatus @default(PENDING)

  // Circle transfer id
  circleTransferId String?
  txHash           String?

  @@map("transfers")
}

model PaymentRequest {
  id          String              @id @default(cuid())
  createdAt   DateTime            @default(now())
  expiresAt   DateTime?

  userId      String
  user        User                @relation(fields: [userId], references: [id])

  code        String              @unique @default(cuid())
  amountUsdc  String?             // null = any amount
  note        String?
  status      PaymentRequestStatus @default(ACTIVE)

  @@map("payment_requests")
}

model ClaimableLink {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  expiresAt   DateTime?

  senderId    String
  sender      User              @relation(fields: [senderId], references: [id])

  code        String            @unique
  amountUsdc  String
  note        String?
  status      ClaimableLinkStatus @default(UNCLAIMED)

  // Who claimed it
  claimedBy   String?           // wallet address or user id
  claimedAt   DateTime?

  // Circle escrow wallet holding the funds
  escrowWalletId String?

  @@map("claimable_links")
}

enum TransferStatus {
  PENDING
  COMPLETE
  FAILED
}

enum PaymentRequestStatus {
  ACTIVE
  PAID
  CANCELLED
  EXPIRED
}

enum ClaimableLinkStatus {
  UNCLAIMED
  CLAIMED
  CANCELLED
  EXPIRED
}

model Invoice {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  creatorId   String
  creator     User          @relation(fields: [creatorId], references: [id])

  code        String        @unique @default(cuid())

  title       String
  description String?
  amountUsdc  String

  // Proof of work
  proofNote     String?
  proofImageUrl String?

  status      InvoiceStatus @default(PENDING)
  paidAt      DateTime?

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

model Waitlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  email     String   @unique

  @@map("waitlist")
}
