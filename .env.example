# Database (Supabase — use transaction pooler for Vercel serverless)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use session pooler (port 5432, no ?pgbouncer) for local prisma db push / migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Privy (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"

# Circle Developer Controlled Wallets (https://console.circle.com)
CIRCLE_API_KEY="your-circle-api-key"
CIRCLE_ENTITY_SECRET="your-circle-entity-secret"
CIRCLE_WALLET_SET_ID="your-circle-wallet-set-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Smart Contracts (Arc Testnet — Chain ID 5042002)
NEXT_PUBLIC_ESCROW_ADDRESS="0x31D4F6B87E042D4849B586880d30c0D6102Ba2cd"
NEXT_PUBLIC_INVOICE_REGISTRY_ADDRESS="0x87090C9d427e71c8E2661D483a11A8DeE3a9Bd88"

# Hardhat / contract deployment (never commit real private key)
PRIVATE_KEY="0x..."